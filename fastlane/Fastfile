# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

platform :ios do
  # ============================
  # CD用 lane（TestFlight 配信）
  # ============================
  desc "CD用 TestFlightアップロード"
  lane :cd_release do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8"],
      is_key_content_base64: false
    )

    match(
      type: "appstore",
      readonly: true
    )

    # デフォルトは CI Test Plan
    test_plan = options[:testplan] || "CI"

    run_tests(
      scheme: "Zidosuta",
      testplan: test_plan,
      devices: ["iPhone 14"],
      clean: true,
      fail_build: true
    )

    build_app(
      scheme: "Zidosuta",
      clean: true,
      export_method: "app-store"
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: "dev.Kawashima.Zidosuta",
      skip_waiting_for_build_processing: true
    )
  end

  # ============================
  # CI用 lane（featureブランチ）
  # ============================
  desc "featureブランチ用 CIテスト（Test Plan: CI）"
  lane :ci_test do
    run_tests(
      scheme: "Zidosuta",
      testplan: "CI",
      devices: ["iPhone 14"],
      clean: true,
      fail_build: true
    )
  end
end

